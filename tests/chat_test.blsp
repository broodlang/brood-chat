;; Tests for the chat module's pure core — the model, the update folds, command
;; dispatch, Tab completion and the view helpers. `(:use chat)` brings chat's public
;; defs into scope; the internal `chat--` helpers stay private to the module (`:use`
;; doesn't re-export the `--` names), so we reach them qualified as `chat/chat--…`.
;; `(:use test)` brings the describe/test/assert=/is/refute macros. `nest test`
;; loads src/ first, so `chat` is available.
;;
;; The input line is a `editor/lineedit` state on `:edit` (text + point + kill-ring +
;; history), so editing is driven through `chat-update` with key inputs and asserted
;; via the edit state's `:text`/`:point`.
;;
;; The networked paths (broadcast, connect, mesh convergence, history backfill over
;; the wire) aren't exercised here — they need live nodes; see `repro/mesh.sh`,
;; `repro/tcp.sh`, and `repro/run.sh` for those regression checks.
(defmodule chat-test (:use chat) (:use test))

(defn last-entry (m)
  "The most recent log entry of model `m`."
  (last (get m :log)))

(defn input-text (m)
  "The input line's current text."
  (get (get m :edit) :text))

(defn input-point (m)
  "The input line's cursor position."
  (get (get m :edit) :point))

(defn feed (m keys)
  "Fold a list of key inputs through `chat-update`."
  (fold (fn (m k) (chat-update m k 80 24)) m keys))

(defn type-line (m s)
  "Type string `s` into the model one character at a time."
  (feed m (string->list s)))

(describe "chat: model & input"
  (test "init seeds one system line and an empty input editor"
    (let (m (chat-init "alice"))
      (assert= (input-text m) "")
      (assert= (input-point m) 0)
      (assert= (get m :name) "alice")
      (refute (get m :done))
      (assert= (count (get m :log)) 1)
      (assert= (get (first (get m :log)) :kind) :system)))

  (test "printable keys extend the line, backspace trims it"
    (let (m (type-line (chat-init "a") "hi"))
      (assert= (input-text m) "hi")
      (assert= (input-text (chat-update m :backspace 80 24)) "h")))

  (test "cursor motion: C-a / C-f edit mid-line"
    (let (m (feed (type-line (chat-init "a") "bc") [:ctrl-a "a"]))
      (assert= (input-text m) "abc")
      (assert= (input-point m) 1)))

  (test "kill and yank round-trip the line (C-u / C-y)"
    (let (m (feed (type-line (chat-init "a") "hello") [:ctrl-u :ctrl-y]))
      (assert= (input-text m) "hello")))

  (test "tick and unhandled inputs are no-ops on the line"
    (let (m (type-line (chat-init "a") "x"))
      (assert= (input-text (chat-update m :tick 80 24)) "x")
      (assert= (input-text (chat-update m [:mouse 1 1] 80 24)) "x")))

  (test "a submitted line is recalled by history (↑)"
    (let (m (feed (type-line (chat-init "a") "/nodes") [:enter :up]))
      (assert= (input-text m) "/nodes")))

  (test "quit keys set :done — and mid-line C-d deletes forward instead"
    (is (get (chat-update (chat-init "a") :ctrl-c 80 24) :done))
    (is (get (chat-update (chat-init "a") :escape 80 24) :done))
    ; empty line → EOF quits
    (is (get (chat-update (chat-init "a") :ctrl-d 80 24) :done))
    (let (m (feed (type-line (chat-init "a") "ab") [:ctrl-a :ctrl-d]))
      (refute (get m :done))
      (assert= (input-text m) "b"))))

(describe "chat: submit & commands"
  (test "a plain line echoes into the log as :me and resets the editor"
    (let (m (chat-update (type-line (chat-init "a") "hello") :enter 80 24))
      (assert= (input-text m) "")
      (assert= (get (last-entry m) :kind) :me)
      (assert= (get (last-entry m) :text) "hello")))

  (test "/quit sets :done"
    (is (get (chat/chat--submit (chat-init "a") "/quit") :done)))

  (test "blank input is a no-op submit"
    (let (m (chat/chat--submit (chat-init "a") "   "))
      (assert= (count (get m :log)) 1)))

  (test "/nodes logs a system line"
    (let (m (chat/chat--submit (chat-init "a") "/nodes"))
      (assert= (get (last-entry m) :kind) :system))))

(describe "chat: tab completion"
  (test "a unique prefix fills the whole command in"
    (let (m (chat-update (type-line (chat-init "a") "/co") :tab 80 24))
      (assert= (input-text m) "/connect ")
      (assert= (input-point m) 9)))

  (test "an ambiguous prefix fills the shared prefix and lists matches"
    (let (m (chat-update (type-line (chat-init "a") "/") :tab 80 24))
      (is (starts-with? (input-text m) "/"))
      (assert= (get (last-entry m) :kind) :system)))

  (test "no match leaves the line untouched"
    (assert= (input-text (chat-update (type-line (chat-init "a") "/zzz") :tab 80 24)) "/zzz")))

(describe "chat: incoming peer messages"
  ;; conversational shapes are map payloads: [:chat {:from :text :room :lc :at}], etc.
  (test "[:chat …] becomes a :them entry tagged with the sender"
    (let (m (chat/chat--handle-peer (chat-init "a") [:chat {:from :bob :text "hi" :lc 1}]))
      (assert= (get (last-entry m) :kind) :them)
      ; node keyword shown without its colon
      (assert= (get (last-entry m) :from) "bob")
      (assert= (get (last-entry m) :text) "hi")))

  (test "[:result from label r] renders the closure's return"
    (let (m (chat/chat--handle-peer (chat-init "a") [:result :bob "say-hi" "ok"]))
      (assert= (get (last-entry m) :kind) :result)))

  ;; chat-update must route a peer message to handle-peer in BOTH shapes it can arrive
  ;; in: wrapped [:peer msg] (the terminal, via chat--with-peers) and raw [:chat …] (the
  ;; GUI, whose catch-all poll returns mailbox messages unwrapped). The raw form was the
  ;; group-chat bug — GUI peers connected but never saw each other's lines.
  (test "chat-update handles a WRAPPED peer message (terminal path)"
    (let (m (chat-update (chat-init "a") [:peer [:chat {:from :bob :text "hi there" :lc 1}]] 80 24))
      (assert= (get (last-entry m) :kind) :them)
      (assert= (get (last-entry m) :text) "hi there")))

  (test "chat-update handles a RAW peer message (GUI path — the group-chat fix)"
    (let (m (chat-update (chat-init "a") [:chat {:from :bob :text "gui line" :lc 1}] 80 24))
      (assert= (get (last-entry m) :kind) :them)
      (assert= (get (last-entry m) :from) "bob")
      (assert= (get (last-entry m) :text) "gui line")))

  (test "a raw [:action …] and [:history …] also route through (GUI path)"
    (let (m (chat-update (chat-init "a") [:action {:from :bob :text "waves" :lc 1}] 80 24))
      (assert= (get (last-entry m) :kind) :action))
    ;; a raw history dump is folded (backfilled), not treated as a keystroke
    (let (m (chat-update (chat-init "a")
              [:history [{:from "z" :text "earlier" :lc 1 :at 1}]]
              80
              24))
      (assert= (get m :backfilled) true)))

  (test "a real keystroke is NOT mistaken for a peer message"
    ;; strings, keywords, and [:mouse …] carry no peer tag → left for the editor
    (is (nil? (chat/chat--peer-msg "a")))
    (is (nil? (chat/chat--peer-msg :up)))
    (is (nil? (chat/chat--peer-msg [:mouse :scroll-up 0 0])))
    (assert= (chat/chat--peer-msg [:peer [:chat {:from :b :text "x"}]])
      [:chat {:from :b :text "x"}])
    (assert= (chat/chat--peer-msg [:dm {:from :b :text "x"}]) [:dm {:from :b :text "x"}])))

(describe "chat: presence (cluster mesh → :peers)"
  ;; chat--reconcile reads live (nodes); its pure diff core chat--sync-peers takes the
  ;; node list explicitly, so join/leave detection is testable without two live nodes.
  (test "a newly-seen node is stored and logged as connected"
    (let (m (chat/chat--sync-peers (chat-init "a") [:bob@host]))
      (assert= (get m :peers) [:bob@host])
      (assert= (get (last-entry m) :kind) :system)
      (assert= (get (last-entry m) :text) "bob@host connected")))

  (test "a node that has left is dropped and logged as disconnected"
    (let (m0 (chat/chat--sync-peers (chat-init "a") [:bob@host :cora@host])
          m1 (chat/chat--sync-peers m0 [:cora@host]))
      (assert= (get m1 :peers) [:cora@host])
      (assert= (get (last-entry m1) :text) "bob@host disconnected")))

  (test "no membership change adds no log lines"
    (let (m0 (chat/chat--sync-peers (chat-init "a") [:bob@host])
          n0 (count (get m0 :log))
          m1 (chat/chat--sync-peers m0 [:bob@host]))
      (assert= (count (get m1 :log)) n0)
      (assert= (get m1 :peers) [:bob@host])))

  (test "/nodes reports the model's peer set"
    (let (m (chat/chat--submit (assoc (chat-init "a") :peers [:bob@host :cora@host]) "/nodes"))
      (assert= (get (last-entry m) :kind) :system)
      (assert= (get (last-entry m) :text) "connected: bob@host, cora@host"))))

; UTC-1 wraps back a day
(describe "chat: nick, actions & timestamps"
  (test "/nick renames you and logs it; blank is a no-op"
    (let (m (chat/chat--submit (chat-init "alice") "/nick bob"))
      (assert= (get m :name) "bob")
      (assert= (get (last-entry m) :kind) :system)
      (assert= (get (last-entry m) :text) "you are now bob"))
    (assert= (get (chat/chat--submit (chat-init "alice") "/nick    ") :name) "alice"))

  (test "/me logs an :action attributed to the current name"
    (let (m (chat/chat--submit (chat-init "alice") "/me waves"))
      (assert= (get (last-entry m) :kind) :action)
      (assert= (get (last-entry m) :from) "alice")
      (assert= (get (last-entry m) :text) "waves")))

  (test "a plain send is stamped with a raw epoch time"
    (let (m (chat/chat--submit (chat-init "a") "hello"))
      (is (number? (get (last-entry m) :at)))))

  (test "an incoming action becomes an :action entry"
    (let (m (chat/chat--handle-peer (chat-init "a") [:action {:from :bob :text "shrugs" :lc 1}]))
      (assert= (get (last-entry m) :kind) :action)
      (assert= (get (last-entry m) :from) "bob")))

  (test "hhmm formats epoch-ms as zero-padded HH:MM, applying the tz offset and wrapping"
    (assert= (chat/chat--hhmm 0 0) "00:00")
    (assert= (chat/chat--hhmm 60000 0) "00:01")
    (assert= (chat/chat--hhmm (+ (* 13 3600000) (* 45 60000)) 0) "13:45")
    (assert= (chat/chat--hhmm (* 24 3600000) 0) "00:00")
    ; UTC+2
    (assert= (chat/chat--hhmm 0 120) "02:00")
    (assert= (chat/chat--hhmm 0 -60) "23:00"))

  (test "/tz sets the offset from a signed hour count and rejects junk"
    (assert= (get (chat/chat--submit (chat-init "a") "/tz +2") :tz-offset) 120)
    (assert= (get (chat/chat--submit (chat-init "a") "/tz -5") :tz-offset) -300)
    (assert= (get (chat/chat--submit (chat-init "a") "/tz nope") :tz-offset) 0)
    (assert= (chat/chat--parse-tz "+2") 120)
    (assert= (chat/chat--parse-tz "0") 0)
    (assert= (chat/chat--parse-tz "x") nil)))

(describe "chat: history backfill"
  ; the action flagged
  (test "history-entries yields neutral records; own lines take the display name"
    (let (m (assoc (chat-init "alice")
              :log [{:kind :system :text "welcome"} {:kind :me :text "hi" :at "10:00"}
                     {:kind :them :from "bob" :text "yo" :at "10:01"}
                     {:kind :action :from "bob" :text "waves" :at "10:02"}])
          hs (chat/chat--history-entries m))
      ; system line dropped
      (assert= (count hs) 3)
      ; :me attributed to :name
      (assert= (get (first hs) :from) "alice")
      (assert= (get (first hs) :text) "hi")
      (is (get (nth hs 2) :act))))
  (test "receiving history splices it after the welcome and only once"
    (let (recs [{:from "bob" :text "earlier" :at "09:00" :act false}]
          m1 (chat/chat--handle-peer (chat-init "alice") [:history recs]))
      (is (get m1 :backfilled))
      (assert= (get (first (get m1 :log)) :text)
        "welcome, alice — /join a room · /connect a peer · @nick to ping · /help")
      (refute (empty? (filter (fn (e) (= (get e :text) "earlier")) (get m1 :log))))
      ;; a second dump (e.g. from another peer we asked) is ignored
      (let (m2 (chat/chat--handle-peer m1 [:history [{:from "z" :text "again" :lc 9 :at 1}]]))
        (is (empty? (filter (fn (e) (= (get e :text) "again")) (get m2 :log)))))))

  (test "a want-history request leaves our own model unchanged"
    (let (m0 (chat-init "alice")
          m1 (chat/chat--handle-peer m0 [:want-history :bob@host]))
      (assert= (get m1 :log) (get m0 :log)))))

(describe "chat: node identity parsing"
  (test "a bare name is a local node; name@host:port is a TCP listen address"
    (assert= (chat/chat--parse-identity "alice") ["alice" nil])
    (assert= (chat/chat--parse-identity "alice@0.0.0.0:9001") ["alice" "0.0.0.0:9001"])
    (assert= (chat/chat--parse-identity "alice@host") ["alice@host" nil]))

  (test "short strips the @host qualifier"
    (assert= (chat/chat--short :bob@whkbus) "bob")
    (assert= (chat/chat--short "alice@10.0.0.4:9001") "alice")
    (assert= (chat/chat--short "carol") "carol"))

  (test "launch args: a frontend token is recognised anywhere; the name is the rest"
    (assert= (chat/chat--mode-arg ["--with-tui"]) :tui)
    (assert= (chat/chat--mode-arg ["alice" "gui"]) :gui)
    (assert= (chat/chat--mode-arg ["alice"]) nil)
    (assert= (chat/chat--name-arg ["tui" "alice@0.0.0.0:9001"]) "alice@0.0.0.0:9001")
    (assert= (chat/chat--name-arg ["--with-gui"]) nil)))

(describe "chat: resilience"
  (test "a malformed /run is reported, not fatal, and ships nothing"
    (let (m (chat/chat--submit (chat-init "a") "/run (+ 1"))
      (assert= (get (last-entry m) :kind) :system)
      (is (starts-with? (get (last-entry m) :text) "bad /run"))))

  (test "a well-formed /run logs that it shipped"
    (let (m (chat/chat--submit (chat-init "a") "/run (+ 1 2)"))
      (assert= (get (last-entry m) :text) "shipped closure: (+ 1 2)")))

  (test "a malformed history dump is tolerated and still marks backfilled"
    (let (m (chat/chat--handle-peer (chat-init "a") [:history "garbage"]))
      (is (get m :backfilled))
      (is (empty? (filter (fn (e) (= (get e :kind) :them)) (get m :log))))))

  (test "a failed background dial reports which peer it couldn't reach"
    (let (m (chat/chat--handle-peer (chat-init "a") [:dial-failed :bob@host]))
      (assert= (get (last-entry m) :text) "couldn't reach bob")))

  (test "/connect guards against yourself and an already-connected peer"
    ; (node-name) is :nonode in a test
    (assert= (get (last-entry (chat/chat--do-connect (chat-init "a") "nonode")) :text)
      "can't connect to yourself")
    (assert= (get (last-entry (chat/chat--do-connect (assoc (chat-init "a") :peers [:bob@host])
                                "bob"))
               :text)
      "already connected to bob"))

  (test "chat-update never throws on malformed or unknown inputs"
    (is (map? (chat-update (chat-init "a") [:peer [:history "x"]] 80 24)))
    (is (map? (chat-update (chat-init "a") [:peer [:weird 1 2]] 80 24)))
    (is (map? (chat-update (chat-init "a") :some-unknown-key 80 24)))))

(describe "chat: scrollback"
  (test "PgUp scrolls the backlog; PgDn and the wheel move it back"
    (let (m (chat-update (chat-init "a") :page-up 80 24))
      ; page = rows-4
      (assert= (get m :scroll) 20)
      (assert= (get (chat-update m :page-down 80 24) :scroll) 0)
      (assert= (get (chat-update (chat-init "a") [:mouse :scroll-up nil 3 3 []] 80 24) :scroll) 3)))

  (test "sending a line jumps back to the live bottom"
    (let (m0 (chat-update (chat-init "a") :page-up 80 24)
          m1 (feed m0 (string->list "hi"))
          m2 (chat-update m1 :enter 80 24))
      (assert= (get m2 :scroll) 0))))

(describe "chat: help & clear"
  (test "/help logs the command summary"
    (let (m (chat/chat--submit (chat-init "a") "/help"))
      (is (starts-with? (get (last-entry m) :text) "commands:"))))

  (test "/clear wipes the log and returns to live"
    (let (m (chat/chat--submit (assoc (chat-init "a") :scroll 4) "/clear"))
      (assert= (count (get m :log)) 1)
      (assert= (get m :scroll) 0))))

(describe "chat: mentions, unread & attention"
  (test "mentions? spots an @name case-insensitively; blank name never matches"
    (is (chat/chat--mentions? "hey @ada, look" "ada"))
    (is (chat/chat--mentions? "HEY @ADA" "ada"))
    (refute (chat/chat--mentions? "hello there" "ada"))
    (refute (chat/chat--mentions? "@ada" "")))

  ; unfocused
  (test "present? is true only when focused, at the bottom, and viewing that room"
    (let (m (chat-init "ada"))
      ; focused, scroll 0, #lobby
      (is (chat/chat--present? m "#lobby" false))
      ; a DM shows in any room
      (is (chat/chat--present? m "#dev" true))
      ; wrong room
      (refute (chat/chat--present? m "#dev" false))
      ; scrolled away
      (refute (chat/chat--present? (assoc m :scroll 2) "#lobby" false))
      (refute (chat/chat--present? (assoc m :focused false) "#lobby" false))))
  (test "an @-mention pings ONLY when you wouldn't already see it"
    ;; present (focused, bottom, same room) → no badge; you're looking right at it
    (let (m (chat/chat--handle-peer (chat-init "ada") [:chat {:from :bob :text "ping @ada" :lc 1}]))
      (assert= (get m :mentions) 0))
    ;; unfocused → badge
    (let (away (chat/chat-update (chat-init "ada") :blur 80 24)
          m (chat/chat--handle-peer away [:chat {:from :bob :text "ping @ada" :lc 1}]))
      (assert= (get m :mentions) 1))
    ;; a non-mention never pings
    (let (away (chat/chat-update (chat-init "ada") :blur 80 24)
          m (chat/chat--handle-peer away [:chat {:from :bob :text "hello all" :lc 1}]))
      (assert= (get m :mentions) 0)))

  (test ":blur drops focus; any keystroke regains it (GUI focus tracking)"
    (let (m (chat-update (chat-init "a") :blur 80 24))
      (refute (get m :focused))
      (is (get (chat-update m "x" 80 24) :focused))))

  (test "a line arriving while scrolled up increments unread; catching up clears it"
    (let (up (assoc (chat-init "a") :scroll 3)
          m1 (chat/chat--handle-peer up [:chat {:from :bob :text "hi" :lc 1}]))
      (assert= (get m1 :unread) 1)
      ;; scrolling back to the bottom clears unread + mentions
      (let (m2 (chat/chat--scroll (assoc m1 :mentions 2) -999))
        (assert= (get m2 :scroll) 0)
        (assert= (get m2 :unread) 0)
        (assert= (get m2 :mentions) 0)))))

(describe "chat: rooms"
  (test "/join switches room, registers it, and pins to the bottom"
    (let (m (chat/chat--submit (assoc (chat-init "a") :scroll 5) "/join #dev"))
      (assert= (get m :room) "#dev")
      (is (member? "#dev" (get m :rooms)))
      (assert= (get m :scroll) 0)))

  (test "a bare room name gains a leading # and is case-folded"
    (assert= (chat/chat--room-name "Dev") "#dev")
    (assert= (chat/chat--room-name "  #Ops ") "#ops"))

  (test "a sent line is tagged with the current room; the view filters by room"
    (let (m (chat/chat--submit (assoc (chat-init "a") :room "#dev") "hi dev"))
      (assert= (get (last-entry m) :room) "#dev")
      ; a #dev line is hidden while you're in #lobby, shown while in #dev
      (refute (chat/chat--visible? (last-entry m) "#lobby"))
      (is (chat/chat--visible? (last-entry m) "#dev"))
      ; system/DM entries show in any room
      (is (chat/chat--visible? {:kind :system :text "x"} "#lobby"))))

  (test "/rooms lists the rooms seen"
    (let (m (chat/chat--submit (assoc (chat-init "a") :rooms ["#lobby" "#dev"]) "/rooms"))
      (is (string-contains? (get (last-entry m) :text) "#dev")))))

(describe "chat: private messages (/msg)"
  (test "/msg to a connected peer logs a :dm-out addressed to them"
    (let (m (chat/chat--submit (assoc (chat-init "a") :peers [:bob@host]) "/msg bob psst"))
      (assert= (get (last-entry m) :kind) :dm-out)
      (assert= (get (last-entry m) :from) "bob")
      (assert= (get (last-entry m) :text) "psst")))

  (test "/msg to an unknown nick is a friendly note, not a send"
    (let (m (chat/chat--submit (assoc (chat-init "a") :peers [:bob@host]) "/msg nobody hi"))
      (assert= (get (last-entry m) :kind) :system)
      (is (string-contains? (get (last-entry m) :text) "no connected peer"))))

  (test "an incoming [:dm …] logs a :dm-in and pings when you're not looking"
    ;; present → logged, no badge
    (let (m (chat/chat--handle-peer (chat-init "a") [:dm {:from :bob :text "hey" :lc 1}]))
      (assert= (get (last-entry m) :kind) :dm-in)
      (assert= (get (last-entry m) :from) "bob")
      (assert= (get m :mentions) 0))
    ;; unfocused → badge
    (let (away (chat/chat-update (chat-init "a") :blur 80 24)
          m (chat/chat--handle-peer away [:dm {:from :bob :text "hey" :lc 1}]))
      (assert= (get m :mentions) 1)))

  (test "a DM is never replayed in history (private)"
    (let (m (assoc (chat-init "a")
              :log [{:kind :system :text "w"} {:kind :dm-in :from "bob" :text "secret" :lc 1}
                     {:kind :me :text "public" :room "#lobby" :lc 2}])
          hs (chat/chat--history-entries m))
      (assert= (count hs) 1)
      (assert= (get (first hs) :text) "public"))))

(describe "chat: ordering & persistence"
  (test "Lamport clock advances on send and jumps past a peer's on receive"
    (let (m1 (chat/chat--submit (chat-init "a") "one")
          m2 (chat/chat--handle-peer m1 [:chat {:from :bob :text "two" :lc 50}]))
      (assert= (get m1 :lc) 1)
      ; observed 50 → ours becomes 51
      (assert= (get m2 :lc) 51)))

  (test "backfill dedupes already-seen ids and orders the rest by Lamport clock"
    (let (seeded (chat/chat--remember (chat-init "a") (chat/chat--id "bob" 2))
          m (chat/chat--backfill seeded
              [{:from "z" :text "later" :lc 5 :room "#lobby"} {:from "a"
                                                               :text "early"
                                                               :lc 1
                                                               :room "#lobby"}
                {:from "bob" :text "dup" :lc 2 :room "#lobby"}])
          texts (into [] (map (fn (e) (get e :text)) (filter chat/chat--public? (get m :log)))))
      ; "dup" (id bob|2) skipped; the rest sorted 1,5
      (assert= texts ["early" "later"])))

  (test "a live line then its history echo collapse to one (id dedupe)"
    (let (live (chat/chat--handle-peer (chat-init "a") [:chat {:from :bob :text "hi" :lc 7}])
          n (count (filter (fn (e) (= (get e :kind) :them)) (get live :log)))
          echo (chat/chat--handle-peer live
                 [:history [{:from "bob" :text "hi" :lc 7 :room "#lobby"}]])
          n2 (count (filter (fn (e) (= (get e :kind) :them)) (get echo :log))))
      (assert= n 1)
      (assert= n2 1)))

  (test "persistence is batched: a change marks dirty, the tick throttles the write"
    ;; a received/sent line marks the log dirty rather than writing immediately
    (let (m (chat/chat--handle-peer (assoc (chat-init "a") :store "/tmp/none")
              [:chat {:from :bob :text "hi" :lc 1}]))
      (is (get m :dirty))
      ;; a write that just happened → maybe-persist! throttles (stays dirty, no I/O)
      (is (get (chat/chat--maybe-persist! (assoc m :persisted-at (now))) :dirty)))
    ;; no :store → maybe-persist! and flush! are pure no-ops (tests never touch disk)
    (is (map? (chat/chat--maybe-persist! (chat-init "a"))))
    (is (map? (chat/chat--flush! (chat/chat-init "a")))))

  (test "restore splices saved entries back, preserving perspective and advancing the clock"
    (let (saved [{:kind :me :text "mine" :room "#lobby" :lc 4 :at 1} {:kind :them
                                                                      :from "bob"
                                                                      :text "theirs"
                                                                      :room "#lobby"
                                                                      :lc 6
                                                                      :at 2}]
          m (chat/chat--restore (chat-init "a") saved))
      (assert= (get m :lc) 6)
      ; the two lines are present with their original kinds
      (refute (empty? (filter (fn (e) (and (= (get e :kind) :me) (= (get e :text) "mine")))
                        (get m :log))))
      (refute (empty? (filter (fn (e) (= (get e :kind) :them)) (get m :log))))))

  (test "load-entries returns [] for a missing or corrupt file"
    (assert= (chat/chat--load-entries "/tmp/broodchat-does-not-exist-xyz.log") [])))

(describe "chat: roster, grouping & relative time"
  ; no timestamp
  (test "stamp-str shows relative time from :now, HH:MM when :now is unset"
    ; 30s ago
    (assert= (chat/chat--stamp-str 34200000 34230000 0) "  now")
    ; ~2 min ago
    (assert= (chat/chat--stamp-str 34200000 34330000 0) "   2m")
    (assert= (chat/chat--stamp-str 34200000 (+ 34200000 (* 3 3600000)) 0) "   3h")
    ; :now unset → absolute
    (assert= (chat/chat--stamp-str 34200000 0 0) "09:30")
    (assert= (chat/chat--stamp-str nil 34330000 0) ""))
  (test "consecutive lines from one sender are grouped (chip dropped)"
    (let (shown [{:kind :them :from "bob" :text "one" :at 1000} {:kind :them
                                                                 :from "bob"
                                                                 :text "two"
                                                                 :at 1500}
                  {:kind :them :from "cara" :text "hi" :at 1600}]
          flags (into [] (chat/chat--group-flags shown)))
      (assert= flags [false true false]))
    ;; a big time gap breaks the group
    (let (shown [{:kind :them :from "bob" :text "old" :at 0} {:kind :them
                                                              :from "bob"
                                                              :text "new"
                                                              :at 999999}]
          flags (into [] (chat/chat--group-flags shown)))
      (assert= flags [false false])))

  (test "a grouped line blanks the chip but keeps the body column aligned"
    (let (solo (first (chat/chat--entry-vlines {:kind :them :from "bob" :text "hi" :at nil}
                        80
                        0
                        ""
                        0
                        false))
          grp (first (chat/chat--entry-vlines {:kind :them :from "bob" :text "hi" :at nil}
                       80
                       0
                       ""
                       0
                       true))
          ;; the body op is the last op on the line; its column must match
          body-col (fn (line) (nth (last line) 2)))
      (assert= (body-col solo) (body-col grp))))

  ; other room + unread
  (test "the sidebar lists you + peers and marks the current room with unread dots"
    (let (m (assoc (chat-init "ada")
              :peers [:bob@h :cara@h]
              :room "#dev"
              :rooms ["#lobby" "#dev"]
              :room-unread {"#lobby" 3})
          lines (map (fn (l) (get l :text)) (chat/chat--sidebar-lines m)))
      (is (member? "● ada  (you)" lines))
      (is (member? "● bob" lines))
      ; current room marked
      (is (member? "▸ #dev" lines))
      (is (member? "  #lobby  •3" lines))))
  (test "receiving in another room bumps that room's unread; /join clears it"
    (let (m (chat/chat--handle-peer (assoc (chat-init "a") :room "#lobby")
              [:chat {:from :bob :text "hi" :room "#dev" :lc 1}]))
      (assert= (get (get m :room-unread) "#dev") 1)
      (let (joined (chat/chat--submit m "/join #dev"))
        (assert= (get (get joined :room-unread) "#dev") 0))))

  (test "the sidebar hides on a narrow terminal (renders full width)"
    ;; both widths render a valid frame; the narrow one simply omits the panel
    (is (vector? (chat-view (chat-init "a") 50 16)))
    (is (vector? (chat-view (assoc (chat-init "a") :peers [:bob@h]) 90 16)))))

(describe "chat: view helpers"
  (test "rest-after returns the argument past the first space"
    (assert= (chat/chat--rest-after "/connect bob") "bob")
    (assert= (chat/chat--rest-after "/nodes") ""))

  (test "names joins peers without their colons, or a placeholder when empty"
    (assert= (chat/chat--names []) "(none yet)")
    (assert= (chat/chat--names [:alice :bob]) "alice, bob"))

  (test "node-str drops a node keyword's leading colon and passes strings through"
    (assert= (chat/chat--node-str :alice@host) "alice@host")
    (assert= (chat/chat--node-str "bob") "bob"))

  (test "clamp truncates with an ellipsis past the width"
    (assert= (chat/chat--clamp "hello" 10) "hello")
    (assert= (chat/chat--clamp "hello" 3) "he…"))

  (test "peer-color is stable per first letter"
    (assert= (chat/chat--peer-color "bob") (chat/chat--peer-color "bilbo")))

  (test "place-vlines lays visual lines on consecutive rows from the base"
    (let (v0 (chat/chat--entry-vlines {:kind :system :text "x"} 80 0 "" 0 false)
          v1 (chat/chat--entry-vlines {:kind :system :text "y"} 80 0 "" 0 false)
          ops (chat/chat--place-vlines (concat v0 v1) 5))
      (assert= (nth (first ops) 1) 5)
      (assert= (nth (second ops) 1) 6)))

  ; chip starts past the gutter
  (test "a timestamped :them entry puts the tz-formatted stamp in the gutter, chip after"
    ;; 34_200_000 ms = 09:30 UTC; gutter is len(\"09:30\")+1 = 6
    (let (line0 (first (chat/chat--entry-vlines {:kind :them :from "bob" :text "hi" :at 34200000}
                         80
                         0
                         ""
                         0
                         false)))
      ; stamp at col 0
      (assert= (nth (first line0) 2) 0)
      ; now=0 → falls back to tz-formatted HH:MM (UTC)
      (assert= (nth (first line0) 3) "09:30")
      (assert= (nth (second line0) 2) 6)))
  (test "an action renders as ✦ then the name/text body"
    (let (line0 (first (chat/chat--entry-vlines {:kind :action :from "bob" :text "waves"}
                         80
                         0
                         ""
                         0
                         false)))
      (assert= (nth (first line0) 3) "✦ ")
      (is (string-contains? (nth (second line0) 3) "bob waves"))))

  (test "wrap breaks on spaces within the width and hard-splits an over-long word"
    (assert= (chat/chat--wrap "aa bb cc" 5) ["aa bb" "cc"])
    (assert= (chat/chat--wrap "" 10) [""])
    (assert= (chat/chat--wrap "abcdef" 3) ["abc" "def"]))

  (test "a long message wraps across several visual lines"
    (let (vls (chat/chat--entry-vlines {:kind :them
                                        :from "b"
                                        :text "one two three four five six"
                                        :at nil}
                20
                0
                ""
                0
                false))
      (is (> (count vls) 1)))))
